<!DOCTYPE html>
<html lang="kk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Ауыл Дауысы</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Noto+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav>
        <div class="nav-logo">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/6/62/%C2%AB%D0%90%D1%83%D1%8B%D0%BB%C2%BB_%D0%BF%D0%B0%D1%80%D1%82%D0%B8%D1%8F%D1%81%D1%8B%D0%BD%D1%8B%D2%A3_%D0%BB%D0%BE%D0%B3%D0%BE%D1%82%D0%B8%D0%BF%D1%96.png/200px-%C2%AB%D0%90%D1%83%D1%8B%D0%BB%C2%BB_%D0%BF%D0%B0%D1%80%D1%82%D0%B8%D1%8F%D1%81%D1%8B%D0%BD%D1%8B%D2%A3_%D0%BB%D0%BE%D0%B3%D0%BE%D1%82%D0%B8%D0%BF%D1%96.png"
                 alt="Ауыл"
                 style="height:36px; width:auto; vertical-align:middle; margin-right:10px; border-radius:4px;" />
            Ауыл <span>Дауысы</span>
        </div>
        <ul style="display:flex; gap:2rem; list-style:none; align-items:center;">
            <li><a href="/Home/Petitions" style="color:#c8c0b2; text-decoration:none;">Петициялар</a></li>
            <li><a href="/Home/Submit" style="color:#c8c0b2; text-decoration:none;">Мәселе жіберу</a></li>
            <li><a href="/Home/Map">🗺️ Карта</a></li>
            @if (User.Identity!.IsAuthenticated)
            {
                <li style="color:#c8c0b2; font-size:0.85rem;">@User.Identity.Name</li>
                <li>
                    <form method="post" action="/Account/Logout" style="margin:0;">
                        <button type="submit" style="background:transparent; border:1px solid rgba(255,255,255,0.2); color:#c8c0b2; padding:6px 16px; border-radius:4px; cursor:pointer; font-size:0.82rem;">
                            Шығу
                        </button>
                    </form>
                </li>
            }
            else
            {
                <li><a href="/Account/Login" style="color:#c8c0b2; text-decoration:none;">Кіру</a></li>
                <li>
                    <a href="/Account/Register" style="background:#c8923a; color:#fff; padding:8px 20px; border-radius:4px; text-decoration:none; font-size:0.82rem;">
                        Тіркелу
                    </a>
                </li>
            }
        </ul>
    </nav>

    <main>
        @RenderBody()
    </main>

</body>
</html>