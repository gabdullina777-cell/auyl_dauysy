<!-- ЧАТ OVERLAY -->
<div class="chat-overlay" id="chatOverlay" onclick="closeChat()"></div>
<div class="chat-popup" id="chatPopup">
    <div class="chat-header">
        <h3 id="chatTitle">Чат</h3>
        <button onclick="closeChat()" class="chat-close">✕</button>
    </div>
    <div class="chat-messages" id="chatMessages"></div>
    <div class="chat-input-wrap">
        @if (User.Identity!.IsAuthenticated)
        {
            <input type="text" id="chatInput" placeholder="Хабарлама жазыңыз..." class="chat-input" />
            <button onclick="sendMessage()" class="chat-send">Жіберу</button>
        }
        else
        {
            <a href="/Account/Login" class="btn-primary" style="width:100%; text-align:center; display:block;">Чатқа қатысу үшін кіріңіз</a>
        }
    </div>
</div>

<script>
    let currentRegion = '';
    let pollInterval = null;

    function openChat(region) {
        currentRegion = region;
        document.getElementById('chatTitle').textContent = region + ' чаты';
        document.getElementById('chatOverlay').style.display = 'block';
        document.getElementById('chatPopup').style.display = 'flex';
        loadMessages();
        pollInterval = setInterval(loadMessages, 5000);
    }

    function closeChat() {
        document.getElementById('chatOverlay').style.display = 'none';
        document.getElementById('chatPopup').style.display = 'none';
        currentRegion = '';
        if (pollInterval) clearInterval(pollInterval);
    }

    async function loadMessages() {
        if (!currentRegion) return;
        try {
            const res = await fetch('/Chat/GetMessages?region=' + encodeURIComponent(currentRegion));
            const messages = await res.json();
            const container = document.getElementById('chatMessages');
            container.innerHTML = '';

            if (messages.length === 0) {
                container.innerHTML = '<p style="text-align:center;color:#aaa;font-size:0.85rem;margin-top:2rem;">Әзірше хабарлама жоқ. Бірінші болыңыз!</p>';
                return;
            }

            messages.forEach(m => {
                const div = document.createElement('div');
                div.className = 'chat-msg other';
                div.innerHTML = '<strong>' + m.authorName + '</strong><p>' + m.message + '</p><span class="chat-time">' + m.time + '</span>';
                container.appendChild(div);
            });

            container.scrollTop = container.scrollHeight;
        } catch (e) {
            console.log('Қате:', e);
        }
    }

    async function sendMessage() {
        const input = document.getElementById('chatInput');
        const msg = input.value.trim();
        if (!msg || !currentRegion) return;

        try {
            const res = await fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'region=' + encodeURIComponent(currentRegion) + '&message=' + encodeURIComponent(msg)
            });

            if (res.ok) {
                input.value = '';
                await loadMessages();
            } else if (res.status === 401) {
                window.location.href = '/Account/Login';
            }
        } catch (e) {
            console.log('Жіберу қатесі:', e);
        }
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && currentRegion) sendMessage();
    });
</script>