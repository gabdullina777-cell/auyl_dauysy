@{
    ViewData["Title"] = "Ауыл Дауысы";
}

<section class="hero">
    <div class="hero-content">
        <span class="hero-label">Қазақстан ауылдары үшін</span>
        <h1>Сіздің <em>дауысыңыз</em> — өзгерістің бастауы</h1>
        <p class="hero-desc">Ауыл Дауысы — Қазақстанның 2000-нан астам ауылы тұрғындарының мәселелерін мемлекет деңгейіне жеткізетін цифрлық платформа.</p>
        <div class="hero-actions">
            <a href="/Home/Petitions" class="btn-primary">Петицияларды қарау</a>
            <a href="/Account/Register" class="btn-outline">Тіркелу</a>
        </div>
    </div>
    <div class="hero-stats">
        <div class="stat-card">
            <span class="stat-num">@ViewBag.UserCount</span>
            <span class="stat-label">Тіркелген тұрғын</span>
        </div>
        <div class="stat-row">
            <div class="stat-card">
                <span class="stat-num">@ViewBag.PetitionCount</span>
                <span class="stat-label">Белсенді петиция</span>
            </div>
            <div class="stat-card">
                <span class="stat-num">@ViewBag.SolvedCount</span>
                <span class="stat-label">Шешілген мәселе</span>
            </div>
        </div>
    </div>
</section>

<!-- ПАРТИЯ ТУРАЛЫ -->
<section class="about-section">
    <div class="about-grid">
        <div class="about-logo-wrap">
            <img src="https://upload.wikimedia.org/wikipedia/commons/6/62/«Ауыл»_партиясының_логотипі.png"
                 alt="Ауыл партиясы"
                 class="about-logo" />
            <div class="about-badge">Ресми платформа</div>
        </div>
        <div class="about-content">
            <span class="section-label">Партия туралы</span>
            <h2 class="section-title">«Ауыл» партиясы</h2>
            <p>«Ауыл» партиясы — Қазақстан ауылдарының мүддесін қорғайтын саяси күш. 2002 жылы құрылған партия бүгінде еліміздің барлық өңірлерінде белсенді жұмыс атқарады.</p>
            <p style="margin-top:1rem;">Партияның басты мақсаты — ауыл тұрғындарының өмір сүру деңгейін жақсарту, инфрақұрылымды дамыту және ауылдық жерлердегі әлеуметтік мәселелерді шешу.</p>
            <div class="about-stats">
                <div class="about-stat">
                    <strong>2002</strong>
                    <span>Құрылған жыл</span>
                </div>
                <div class="about-stat">
                    <strong>17</strong>
                    <span>Облыстық бөлім</span>
                </div>
                <div class="about-stat">
                    <strong>2000+</strong>
                    <span>Ауыл қамтылған</span>
                </div>
            </div>
        </div>
    </div>
</section>

