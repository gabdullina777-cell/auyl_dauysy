@{
    ViewData["Title"] = "ИИ Петиция Көмекшісі";
}

<div style="max-width:800px;margin:0 auto;padding:3rem 2rem;">

    <div style="text-align:center;margin-bottom:3rem;">
        <span class="section-label">Жасанды интеллект</span>
        <h1 class="section-title" style="font-size:2.4rem;">ИИ Петиция Көмекшісі</h1>
        <p style="color:var(--muted);font-size:1rem;line-height:1.8;max-width:560px;margin:0 auto;">
            Мәселеңізді қысқаша сипаттаңыз — ИИ толық, грамотты петиция мәтінін жазып береді
        </p>
    </div>

    @if (!User.Identity!.IsAuthenticated)
    {
        <div style="background:var(--cream);border:1px solid rgba(200,146,58,0.3);border-radius:12px;padding:2rem;text-align:center;margin-bottom:2rem;">
            <div style="font-size:2.5rem;margin-bottom:1rem;">🔒</div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--dark-green);margin-bottom:0.75rem;">
                Тіркелу қажет
            </h3>
            <p style="color:var(--muted);font-size:0.9rem;margin-bottom:1.5rem;">
                ИИ Петиция Көмекшісін пайдалану үшін алдымен тіркеліңіз
            </p>
            <div style="display:flex;gap:1rem;justify-content:center;">
                <a href="/Account/Register" class="btn-primary">Тіркелу →</a>
                <a href="/Account/Login" class="btn-outline" style="color:var(--dark-green)!important;border-color:rgba(0,0,0,0.2)!important;">Кіру</a>
            </div>
        </div>
    }

    <div style="background:#fff;border-radius:16px;border:1px solid var(--border);padding:2.5rem;margin-bottom:2rem;">
        <form method="post" action="/Home/AiHelper">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Мәселеңізді қысқаша сипаттаңыз</label>
                <textarea name="problemText" rows="4"
                          placeholder="Мысалы: Ауылымыздың жолы өте нашар, жаңбырда балалар мектепке бара алмайды..."
                          required
                          style="width:100%;padding:12px 14px;border:1.5px solid rgba(0,0,0,0.1);border-radius:8px;font-family:'Noto Sans',sans-serif;font-size:0.9rem;resize:vertical;outline:none;">@ViewBag.Problem</textarea>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-group">
                    <label>Облыс</label>
                    <select name="region" required>
                        <option value="">Таңдаңыз</option>
                        <option>Алматы облысы</option>
                        <option>Алматы қаласы</option>
                        <option>Астана қаласы</option>
                        <option>Шымкент қаласы</option>
                        <option>Шығыс Қазақстан облысы</option>
                        <option>Батыс Қазақстан облысы</option>
                        <option>Солтүстік Қазақстан облысы</option>
                        <option>Ақмола облысы</option>
                        <option>Павлодар облысы</option>
                        <option>Қарағанды облысы</option>
                        <option>Ақтөбе облысы</option>
                        <option>Атырау облысы</option>
                        <option>Маңғыстау облысы</option>
                        <option>Қостанай облысы</option>
                        <option>Қызылорда облысы</option>
                        <option>Оңтүстік Қазақстан облысы</option>
                        <option>Жамбыл облысы</option>
                        <option>Абай облысы</option>
                        <option>Жетісу облысы</option>
                        <option>Ұлытау облысы</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Санат</label>
                    <select name="category" required>
                        <option value="">Таңдаңыз</option>
                        <option>Жол</option>
                        <option>Су</option>
                        <option>Білім</option>
                        <option>Денсаулық</option>
                        <option>Газификация</option>
                        <option>Интернет</option>
                        <option>Электр қуаты</option>
                        <option>Тұрғын үй</option>
                        <option>Басқа</option>
                    </select>
                </div>
            </div>

            @if (User.Identity!.IsAuthenticated)
            {
                <button type="submit" class="btn-primary"
                        style="width:100%;padding:14px;font-size:1rem;margin-top:0.5rem;">
                    🤖 Петиция жасат →
                </button>
            }
            else
            {
                <a href="/Account/Register" class="btn-primary"
                       style="width:100%;padding:14px;font-size:1rem;text-align:center;display:block;margin-top:0.5rem;">
                    Пайдалану үшін тіркеліңіз →
                </a>
            }
        </form>
    </div>

    @if (ViewBag.Error != null)
    {
        <div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:8px;padding:16px;color:#c53030;margin-bottom:2rem;">
            ⚠️ @ViewBag.Error
        </div>
    }

    @if (ViewBag.Result != null)
    {
        <div style="background:#fff;border-radius:16px;border:1px solid var(--border);padding:2.5rem;animation:slideIn 0.4s ease;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
                <div>
                    <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--dark-green);">
                        ИИ жасаған петиция
                    </h3>
                    <p style="font-size:0.82rem;color:var(--muted);margin-top:4px;">
                        Мәтінді өңдеп, петиция бетіне қойыңыз
                    </p>
                </div>
                <button onclick="copyText()" class="btn-primary" style="padding:8px 20px;font-size:0.82rem;">
                    📋 Көшіру
                </button>
            </div>

            <div id="resultText"
                 style="white-space:pre-wrap;font-size:0.92rem;line-height:1.9;color:var(--text);background:var(--cream);padding:1.5rem;border-radius:8px;">
                @ViewBag.Result
            </div>

            <div style="margin-top:1.5rem;display:flex;gap:1rem;align-items:center;flex-wrap:wrap;">
                <a href="/Home/Submit" class="btn-primary">
                    ✍️ Петиция бетіне өту →
                </a>
                <span style="color:var(--muted);font-size:0.85rem;">
                    Мәтінді көшіріп, петиция бетінің сипаттама өрісіне қойыңыз
                </span>
            </div>
        </div>
    }

    @if (ViewBag.Result == null && ViewBag.Error == null)
    {
        <div style="background:var(--cream);border-radius:12px;padding:2rem;text-align:center;">
            <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--dark-green);margin-bottom:1rem;">
                Қалай жұмыс істейді?
            </h4>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;max-width:600px;margin:0 auto;">
                <div>
                    <div style="font-size:1.8rem;margin-bottom:0.5rem;">✍️</div>
                    <p style="font-size:0.82rem;color:var(--muted);">Мәселеңізді қысқаша жазыңыз</p>
                </div>
                <div>
                    <div style="font-size:1.8rem;margin-bottom:0.5rem;">🤖</div>
                    <p style="font-size:0.82rem;color:var(--muted);">ИИ толық петиция жасайды</p>
                </div>
                <div>
                    <div style="font-size:1.8rem;margin-bottom:0.5rem;">📤</div>
                    <p style="font-size:0.82rem;color:var(--muted);">Петицияны жариялаңыз</p>
                </div>
            </div>
        </div>
    }
</div>

<script>
    function copyText() {
        const text = document.getElementById('resultText').innerText;
        navigator.clipboard.writeText(text).then(() => {
            const btn = event.target;
            btn.textContent = '✅ Көшірілді!';
            setTimeout(() => btn.textContent = '📋 Көшіру', 2000);
        }).catch(() => {
            alert('Мәтінді қолмен көшіріңіз');
        });
    }
</script>